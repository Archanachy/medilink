## Staging Environment Configuration
## Use: flutter run --dart-define-from-file=.env.staging

# API Configuration
API_BASE_URL=https://staging-api.medilink.com
WEBSOCKET_URL=wss://staging-api.medilink.com
API_TIMEOUT=30
CONNECTION_TIMEOUT=30

# Firebase Configuration
FIREBASE_PROJECT_ID=medilink-staging
FIREBASE_API_KEY=AIzaSyD_staging_key_here
FIREBASE_AUTH_DOMAIN=medilink-staging.firebaseapp.com
FIREBASE_STORAGE_BUCKET=medilink-staging.appspot.com
FIREBASE_MESSAGING_SENDER_ID=staging_sender_id_here
FIREBASE_APP_ID=1:staging_app_id_here:android:staging_hash_here

# Feature Flags
ENABLE_CHAT=true
ENABLE_VIDEO_CALL=false
ENABLE_PAYMENTS=true
ENABLE_OFFLINE_SYNC=true
ENABLE_CRASH_REPORTING=true

# App Metadata
APP_NAME=MediLink (Staging)
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Cache Settings
CACHE_VALIDITY_HOURS=24
MAX_CACHE_SIZE_MB=50

# File Upload Settings
MAX_IMAGE_SIZE_MB=10
MAX_DOCUMENT_SIZE_MB=50
ENABLE_IMAGE_COMPRESSION=true

# Notification Settings
ENABLE_NOTIFICATIONS=true
ENABLE_LOCAL_NOTIFICATIONS=true

# Security
ENABLE_CODE_OBFUSCATION=true
ENABLE_CERTIFICATE_PINNING=false

# Logging & Analytics
ENABLE_VERBOSE_LOGGING=true
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
