## Production Environment Configuration
## DO NOT commit this file to version control
## Use: flutter run --dart-define-from-file=.env.production

# API Configuration
API_BASE_URL=https://api.medilink.com
WEBSOCKET_URL=wss://api.medilink.com
API_TIMEOUT=30
CONNECTION_TIMEOUT=30

# Firebase Configuration
FIREBASE_PROJECT_ID=medilink-production
FIREBASE_API_KEY=AIzaSyD_production_key_here
FIREBASE_AUTH_DOMAIN=medilink-production.firebaseapp.com
FIREBASE_STORAGE_BUCKET=medilink-production.appspot.com
FIREBASE_MESSAGING_SENDER_ID=production_sender_id_here
FIREBASE_APP_ID=1:production_app_id_here:android:production_hash_here

# Feature Flags
ENABLE_CHAT=true
ENABLE_VIDEO_CALL=false
ENABLE_PAYMENTS=true
ENABLE_OFFLINE_SYNC=true
ENABLE_CRASH_REPORTING=true

# App Metadata
APP_NAME=MediLink
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Cache Settings
CACHE_VALIDITY_HOURS=24
MAX_CACHE_SIZE_MB=50

# File Upload Settings
MAX_IMAGE_SIZE_MB=10
MAX_DOCUMENT_SIZE_MB=50
ENABLE_IMAGE_COMPRESSION=true

# Notification Settings
ENABLE_NOTIFICATIONS=true
ENABLE_LOCAL_NOTIFICATIONS=true

# Security
ENABLE_CODE_OBFUSCATION=true
ENABLE_CERTIFICATE_PINNING=true

# Logging & Analytics
ENABLE_VERBOSE_LOGGING=false
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
